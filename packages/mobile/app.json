{
  "expo": {
    "name": "Exprsn",
    "slug": "exprsn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "exprsn",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.exprsn.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Exprsn needs camera access to record videos",
        "NSMicrophoneUsageDescription": "Exprsn needs microphone access to record audio",
        "NSPhotoLibraryUsageDescription": "Exprsn needs photo library access to upload videos"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "io.exprsn.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Exprsn to access your camera to record videos"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Exprsn to access your photos to upload videos"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
