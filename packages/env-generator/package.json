{
  "name": "@exprsn/env-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "env-gen": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.19.13",
    "typescript": "^5.7.0"
  }
}
