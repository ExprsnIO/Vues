{
  "lexicon": 1,
  "id": "io.exprsn.federation.search",
  "defs": {
    "main": {
      "type": "query",
      "description": "Federated search across all connected appview servers",
      "parameters": {
        "type": "params",
        "required": ["q"],
        "properties": {
          "q": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "description": "Search query"
          },
          "collection": {
            "type": "string",
            "description": "Filter by collection NSID"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 25,
            "description": "Maximum results to return"
          },
          "cursor": {
            "type": "string",
            "description": "Pagination cursor"
          },
          "sort": {
            "type": "string",
            "knownValues": ["relevance", "recent", "popular"],
            "default": "relevance",
            "description": "Sort order for results"
          },
          "author": {
            "type": "string",
            "format": "did",
            "description": "Filter by author DID"
          },
          "since": {
            "type": "string",
            "format": "datetime",
            "description": "Results after this time"
          },
          "until": {
            "type": "string",
            "format": "datetime",
            "description": "Results before this time"
          },
          "tags": {
            "type": "string",
            "description": "Comma-separated list of tags to filter by"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["results", "totalCount", "sources", "queryTimeMs"],
          "properties": {
            "results": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#searchResult"
              }
            },
            "totalCount": {
              "type": "integer",
              "description": "Total number of results across all sources"
            },
            "cursor": {
              "type": "string",
              "description": "Cursor for next page"
            },
            "sources": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#sourceInfo"
              }
            },
            "queryTimeMs": {
              "type": "integer",
              "description": "Total query time in milliseconds"
            }
          }
        }
      }
    },
    "searchResult": {
      "type": "object",
      "required": ["uri", "cid", "collection", "record", "author", "indexedAt"],
      "properties": {
        "uri": {
          "type": "string",
          "format": "at-uri"
        },
        "cid": {
          "type": "string"
        },
        "collection": {
          "type": "string"
        },
        "record": {
          "type": "unknown"
        },
        "author": {
          "type": "object",
          "required": ["did"],
          "properties": {
            "did": {
              "type": "string",
              "format": "did"
            },
            "handle": {
              "type": "string",
              "format": "handle"
            },
            "displayName": {
              "type": "string"
            },
            "avatar": {
              "type": "string"
            }
          }
        },
        "indexedAt": {
          "type": "string",
          "format": "datetime"
        },
        "score": {
          "type": "number",
          "description": "Relevance score"
        },
        "highlights": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field", "snippets"],
            "properties": {
              "field": {
                "type": "string"
              },
              "snippets": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "sourceInfo": {
      "type": "object",
      "required": ["endpoint", "count", "latencyMs"],
      "properties": {
        "endpoint": {
          "type": "string"
        },
        "count": {
          "type": "integer"
        },
        "latencyMs": {
          "type": "integer"
        },
        "error": {
          "type": "string"
        }
      }
    }
  }
}
