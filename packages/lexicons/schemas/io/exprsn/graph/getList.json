{
  "lexicon": 1,
  "id": "io.exprsn.graph.getList",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get a list and its members",
      "parameters": {
        "type": "params",
        "required": ["list"],
        "properties": {
          "list": {
            "type": "string",
            "format": "at-uri",
            "description": "The AT-URI of the list"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["list", "items"],
          "properties": {
            "list": {
              "type": "ref",
              "ref": "io.exprsn.graph.getLists#listView"
            },
            "items": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#listItemView"
              }
            },
            "cursor": { "type": "string" }
          }
        }
      }
    },
    "listItemView": {
      "type": "object",
      "required": ["uri", "subject"],
      "properties": {
        "uri": { "type": "string", "format": "at-uri" },
        "subject": {
          "type": "ref",
          "ref": "io.exprsn.actor.getProfile#profileView"
        }
      }
    }
  }
}
