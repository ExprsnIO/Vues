{
  "lexicon": 1,
  "id": "io.exprsn.graph.getLists",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get lists created by a user",
      "parameters": {
        "type": "params",
        "properties": {
          "did": {
            "type": "string",
            "format": "did",
            "description": "The DID of the user"
          },
          "handle": {
            "type": "string",
            "format": "handle",
            "description": "The handle of the user"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["lists"],
          "properties": {
            "lists": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#listView"
              }
            },
            "cursor": { "type": "string" }
          }
        }
      }
    },
    "listView": {
      "type": "object",
      "required": ["uri", "cid", "creator", "name", "purpose", "indexedAt"],
      "properties": {
        "uri": { "type": "string", "format": "at-uri" },
        "cid": { "type": "string", "format": "cid" },
        "creator": {
          "type": "ref",
          "ref": "io.exprsn.actor.getProfile#profileView"
        },
        "name": { "type": "string" },
        "purpose": { "type": "string" },
        "description": { "type": "string" },
        "avatar": { "type": "string", "format": "uri" },
        "memberCount": { "type": "integer" },
        "indexedAt": { "type": "string", "format": "datetime" },
        "viewer": {
          "type": "object",
          "properties": {
            "muted": { "type": "boolean" },
            "blocked": { "type": "boolean" }
          }
        }
      }
    }
  }
}
