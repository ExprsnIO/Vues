{
  "lexicon": 1,
  "id": "io.exprsn.chat.conversation",
  "defs": {
    "main": {
      "type": "record",
      "description": "A direct message conversation between users",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["members", "createdAt"],
        "properties": {
          "members": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "did"
            },
            "minLength": 2,
            "maxLength": 2,
            "description": "DIDs of the two conversation participants"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "When the conversation was created"
          }
        }
      }
    },
    "conversationView": {
      "type": "object",
      "required": ["id", "members", "createdAt"],
      "properties": {
        "id": {
          "type": "string"
        },
        "members": {
          "type": "array",
          "items": {
            "type": "ref",
            "ref": "#memberView"
          }
        },
        "lastMessage": {
          "type": "ref",
          "ref": "io.exprsn.chat.message#messageView"
        },
        "unreadCount": {
          "type": "integer"
        },
        "muted": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime"
        },
        "updatedAt": {
          "type": "string",
          "format": "datetime"
        }
      }
    },
    "memberView": {
      "type": "object",
      "required": ["did", "handle"],
      "properties": {
        "did": {
          "type": "string",
          "format": "did"
        },
        "handle": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "avatar": {
          "type": "string"
        }
      }
    }
  }
}
