{
  "lexicon": 1,
  "id": "io.exprsn.chat.getConversations",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get list of conversations for the authenticated user",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50,
            "description": "Maximum number of results to return"
          },
          "cursor": {
            "type": "string",
            "description": "Pagination cursor"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["conversations"],
          "properties": {
            "cursor": {
              "type": "string"
            },
            "conversations": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "io.exprsn.chat.conversation#conversationView"
              }
            }
          }
        }
      }
    }
  }
}
