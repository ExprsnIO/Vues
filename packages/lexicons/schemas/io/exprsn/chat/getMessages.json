{
  "lexicon": 1,
  "id": "io.exprsn.chat.getMessages",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get messages in a conversation",
      "parameters": {
        "type": "params",
        "required": ["conversationId"],
        "properties": {
          "conversationId": {
            "type": "string",
            "description": "ID of the conversation"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50,
            "description": "Maximum number of results to return"
          },
          "cursor": {
            "type": "string",
            "description": "Pagination cursor"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["messages"],
          "properties": {
            "cursor": {
              "type": "string"
            },
            "messages": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "io.exprsn.chat.message#messageView"
              }
            }
          }
        }
      }
    }
  }
}
