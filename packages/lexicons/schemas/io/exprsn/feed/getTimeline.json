{
  "lexicon": 1,
  "id": "io.exprsn.feed.getTimeline",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get videos from accounts the user follows (chronological timeline)",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["feed"],
          "properties": {
            "feed": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#feedViewPost"
              }
            },
            "cursor": { "type": "string" }
          }
        }
      }
    },
    "feedViewPost": {
      "type": "object",
      "required": ["post"],
      "properties": {
        "post": {
          "type": "ref",
          "ref": "io.exprsn.video.getVideo#videoView"
        },
        "reason": {
          "type": "union",
          "refs": ["#reasonRepost"]
        }
      }
    },
    "reasonRepost": {
      "type": "object",
      "required": ["$type", "by", "indexedAt"],
      "properties": {
        "$type": { "type": "string", "const": "io.exprsn.feed.getTimeline#reasonRepost" },
        "by": {
          "type": "ref",
          "ref": "io.exprsn.actor.getProfile#profileView"
        },
        "indexedAt": { "type": "string", "format": "datetime" }
      }
    }
  }
}
