{
  "lexicon": 1,
  "id": "io.exprsn.actor.updateProfile",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Update the authenticated user's profile",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "displayName": { "type": "string", "maxLength": 64 },
            "bio": { "type": "string", "maxLength": 256 },
            "avatar": {
              "type": "blob",
              "accept": ["image/png", "image/jpeg", "image/webp"],
              "maxSize": 1000000
            },
            "banner": {
              "type": "blob",
              "accept": ["image/png", "image/jpeg", "image/webp"],
              "maxSize": 2000000
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["success"],
          "properties": {
            "success": { "type": "boolean" },
            "profile": {
              "type": "ref",
              "ref": "io.exprsn.actor.getProfile#profileView"
            }
          }
        }
      }
    }
  }
}
