{
  "lexicon": 1,
  "id": "io.exprsn.actor.searchActors",
  "defs": {
    "main": {
      "type": "query",
      "description": "Search for users by handle or display name",
      "parameters": {
        "type": "params",
        "required": ["q"],
        "properties": {
          "q": {
            "type": "string",
            "description": "Search query"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 25
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["actors"],
          "properties": {
            "actors": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "io.exprsn.actor.getProfile#profileView"
              }
            },
            "cursor": { "type": "string" }
          }
        }
      }
    }
  }
}
