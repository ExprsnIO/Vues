{
  "lexicon": 1,
  "id": "io.exprsn.actor.getSuggestions",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get suggested accounts to follow",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 25
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["actors"],
          "properties": {
            "actors": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "io.exprsn.actor.getProfile#profileView"
              }
            },
            "cursor": { "type": "string" }
          }
        }
      }
    }
  }
}
