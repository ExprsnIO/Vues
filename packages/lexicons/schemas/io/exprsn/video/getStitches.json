{
  "lexicon": 1,
  "id": "io.exprsn.video.getStitches",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get stitches of a video",
      "parameters": {
        "type": "params",
        "required": ["uri"],
        "properties": {
          "uri": {
            "type": "string",
            "format": "at-uri",
            "description": "The URI of the original video"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["stitches"],
          "properties": {
            "stitches": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "io.exprsn.video.getVideo#videoView"
              }
            },
            "cursor": { "type": "string" }
          }
        }
      }
    }
  }
}
