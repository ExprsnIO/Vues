{
  "lexicon": 1,
  "id": "io.exprsn.video.getBookmarks",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get bookmarked videos for the authenticated user",
      "parameters": {
        "type": "params",
        "properties": {
          "folder": {
            "type": "string",
            "description": "Filter by folder name"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 30,
            "description": "Maximum number of results to return"
          },
          "cursor": {
            "type": "string",
            "description": "Pagination cursor"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["bookmarks"],
          "properties": {
            "cursor": {
              "type": "string"
            },
            "bookmarks": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#bookmarkView"
              }
            }
          }
        }
      }
    },
    "bookmarkView": {
      "type": "object",
      "required": ["uri", "video", "createdAt"],
      "properties": {
        "uri": {
          "type": "string",
          "format": "at-uri"
        },
        "video": {
          "type": "ref",
          "ref": "io.exprsn.video.getFeed#feedViewPost"
        },
        "folder": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime"
        }
      }
    }
  }
}
