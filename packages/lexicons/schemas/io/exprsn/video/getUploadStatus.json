{
  "lexicon": 1,
  "id": "io.exprsn.video.getUploadStatus",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get the status of a video upload/processing job",
      "parameters": {
        "type": "params",
        "required": ["uploadId"],
        "properties": {
          "uploadId": {
            "type": "string",
            "description": "Upload ID to check status for"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "knownValues": ["pending", "uploading", "processing", "completed", "failed"]
            },
            "progress": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "description": "Processing progress percentage"
            },
            "cdnUrl": {
              "type": "string",
              "format": "uri",
              "description": "CDN URL when completed"
            },
            "hlsPlaylist": {
              "type": "string",
              "format": "uri",
              "description": "HLS playlist URL when completed"
            },
            "thumbnail": {
              "type": "string",
              "format": "uri",
              "description": "Thumbnail URL when completed"
            },
            "error": {
              "type": "string",
              "description": "Error message if failed"
            }
          }
        }
      }
    }
  }
}
