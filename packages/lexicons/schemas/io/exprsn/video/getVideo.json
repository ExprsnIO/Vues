{
  "lexicon": 1,
  "id": "io.exprsn.video.getVideo",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get a single video post with full details",
      "parameters": {
        "type": "params",
        "required": ["uri"],
        "properties": {
          "uri": {
            "type": "string",
            "format": "at-uri",
            "description": "AT-URI of the video post"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["video"],
          "properties": {
            "video": {
              "type": "ref",
              "ref": "io.exprsn.video.getFeed#feedViewPost"
            }
          }
        }
      }
    }
  }
}
