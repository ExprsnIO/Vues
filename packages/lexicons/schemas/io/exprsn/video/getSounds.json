{
  "lexicon": 1,
  "id": "io.exprsn.video.getSounds",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get trending or search for sounds",
      "parameters": {
        "type": "params",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query for sounds"
          },
          "trending": {
            "type": "boolean",
            "default": false,
            "description": "Get trending sounds"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "default": 20
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["sounds"],
          "properties": {
            "cursor": {
              "type": "string"
            },
            "sounds": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#soundView"
              }
            }
          }
        }
      }
    },
    "soundView": {
      "type": "object",
      "required": ["id", "title"],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "artist": {
          "type": "string"
        },
        "duration": {
          "type": "integer"
        },
        "audioUrl": {
          "type": "string",
          "format": "uri"
        },
        "coverUrl": {
          "type": "string",
          "format": "uri"
        },
        "useCount": {
          "type": "integer",
          "default": 0
        },
        "originalVideoUri": {
          "type": "string",
          "format": "at-uri"
        }
      }
    }
  }
}
