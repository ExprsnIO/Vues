{
  "lexicon": 1,
  "id": "io.exprsn.video.repost",
  "defs": {
    "main": {
      "type": "record",
      "description": "A repost/share of a video to the user's profile",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["subject", "createdAt"],
        "properties": {
          "subject": {
            "type": "ref",
            "ref": "com.atproto.repo.strongRef",
            "description": "Reference to the video being reposted"
          },
          "caption": {
            "type": "string",
            "maxLength": 300,
            "maxGraphemes": 300,
            "description": "Optional caption added to the repost"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "When the repost was created"
          }
        }
      }
    }
  }
}
