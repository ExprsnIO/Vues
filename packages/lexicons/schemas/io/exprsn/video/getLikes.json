{
  "lexicon": 1,
  "id": "io.exprsn.video.getLikes",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get users who liked a video",
      "parameters": {
        "type": "params",
        "required": ["uri"],
        "properties": {
          "uri": {
            "type": "string",
            "format": "at-uri",
            "description": "The URI of the video"
          },
          "cid": {
            "type": "string",
            "format": "cid",
            "description": "The CID of the video (optional, for version specificity)"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["likes"],
          "properties": {
            "likes": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#likeView"
              }
            },
            "cursor": { "type": "string" }
          }
        }
      }
    },
    "likeView": {
      "type": "object",
      "required": ["uri", "author", "indexedAt"],
      "properties": {
        "uri": { "type": "string", "format": "at-uri" },
        "author": {
          "type": "ref",
          "ref": "io.exprsn.actor.getProfile#profileView"
        },
        "indexedAt": { "type": "string", "format": "datetime" }
      }
    }
  }
}
