{
  "lexicon": 1,
  "id": "io.exprsn.notification.updateSeen",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Mark notifications as seen up to a given timestamp",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["seenAt"],
          "properties": {
            "seenAt": {
              "type": "string",
              "format": "datetime",
              "description": "Mark all notifications before this time as seen"
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["success"],
          "properties": {
            "success": { "type": "boolean" }
          }
        }
      }
    }
  }
}
