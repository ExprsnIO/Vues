{
  "lexicon": 1,
  "id": "io.exprsn.sync.getRecords",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get records from a remote server for synchronization",
      "parameters": {
        "type": "params",
        "properties": {
          "collection": {
            "type": "string",
            "description": "Filter by collection NSID"
          },
          "since": {
            "type": "string",
            "format": "datetime",
            "description": "Return records created/updated after this time"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1000,
            "default": 100,
            "description": "Maximum number of records to return"
          },
          "cursor": {
            "type": "string",
            "description": "Pagination cursor"
          },
          "did": {
            "type": "string",
            "format": "did",
            "description": "Filter by author DID"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["records"],
          "properties": {
            "records": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#syncRecord"
              }
            },
            "cursor": {
              "type": "string",
              "description": "Cursor for next page"
            }
          }
        }
      }
    },
    "syncRecord": {
      "type": "object",
      "description": "A record for synchronization",
      "required": ["uri", "cid", "collection", "rkey", "record", "createdAt"],
      "properties": {
        "uri": {
          "type": "string",
          "format": "at-uri",
          "description": "AT-URI of the record"
        },
        "cid": {
          "type": "string",
          "description": "CID of the record"
        },
        "collection": {
          "type": "string",
          "description": "Collection NSID"
        },
        "rkey": {
          "type": "string",
          "description": "Record key"
        },
        "record": {
          "type": "unknown",
          "description": "The record data"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime",
          "description": "When the record was created"
        },
        "updatedAt": {
          "type": "string",
          "format": "datetime",
          "description": "When the record was last updated"
        }
      }
    }
  }
}
