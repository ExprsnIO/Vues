{
  "name": "exprsn",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --concurrency=32",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @exprsn/api db:generate",
    "db:migrate": "pnpm --filter @exprsn/api db:migrate",
    "db:push": "pnpm --filter @exprsn/api db:push",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "lexicon:gen": "pnpm --filter @exprsn/lexicons generate"
  },
  "devDependencies": {
    "@types/node": "^22.19.13",
    "prettier": "^3.4.0",
    "turbo": "^2.8.13",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
