# ==============================================
# Exprsn Development Environment Configuration
# Single .env for all packages (api, web, workers)
# Copy to .env and fill in values:  cp .env.example .env
# ==============================================

# Server
NODE_ENV=development
PORT=3002
HOST=0.0.0.0
APP_URL=http://localhost:3002

# Development Mode
DEV_AUTH_BYPASS=true

# Platform
PLATFORM_NAME=Exprsn.io
PLATFORM_ACCENT_COLOR=#f83b85

# ==============================================
# Next.js (packages/web) — NEXT_PUBLIC_ vars
# ==============================================
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_OAUTH_CLIENT_ID=https://exprsn.io/client-metadata.json
NEXT_PUBLIC_OAUTH_REDIRECT_URI=http://localhost:3001/oauth/callback
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# NEXT_PUBLIC_COLLAB_SERVER_URL=http://localhost:3000

# ==============================================
# Database (PostgreSQL)
# ==============================================
DATABASE_URL=postgresql://exprsn:exprsn_dev@localhost:5432/exprsn

# ==============================================
# Redis (caching, sessions, queues via BullMQ)
# ==============================================
REDIS_URL=redis://localhost:6379

# ==============================================
# OpenSearch (optional - for full-text search)
# ==============================================
OPENSEARCH_URL=http://localhost:9200

# ==============================================
# Object Storage (MinIO for local dev)
# ==============================================
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=exprsn-uploads
DO_SPACES_PROCESSED_BUCKET=exprsn-processed
DO_SPACES_KEY=minioadmin
DO_SPACES_SECRET=minioadmin
DO_SPACES_ENDPOINT=http://localhost:9000
DO_SPACES_CDN=http://localhost:9000/exprsn-processed

# ==============================================
# PDS Configuration (AT Protocol)
# ==============================================
PDS_ENABLED=true
PDS_DOMAIN=localhost:3002
PDS_DID_METHOD=did:exprsn
PDS_DATA_PATH=./data

# Blob Storage
BLOB_STORAGE_TYPE=local
BLOB_STORAGE_PATH=./data/blobs

# ==============================================
# Federation Configuration
# ==============================================

# Relay/Firehose
RELAY_ENABLED=false
RELAY_MAX_BACKFILL=10000
FEDERATION_CONSUMER_ENABLED=false

# DID Resolution
PLC_URL=https://plc.directory
DID_CACHE_TTL=3600
DID_STALE_TTL=86400

# Service Discovery
SERVICE_DOMAIN=localhost:3002
SERVICE_DID=did:web:localhost:3002

# ==============================================
# Jetstream (Bluesky firehose)
# ==============================================
JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe

# ==============================================
# Caching Configuration
# ==============================================
CACHE_DID_TTL=3600
CACHE_PROFILE_TTL=300
CACHE_FEED_TTL=60
CACHE_TRENDING_TTL=300
CACHE_PREFIX=exprsn:

# ==============================================
# Prefetch Configuration
# ==============================================
PREFETCH_ENABLED=true
PREFETCH_PRODUCER_ENABLED=true
# PREFETCH_AUTH_TOKEN=  (generated by setup)
HOT_CACHE_TTL=300000
WARM_CACHE_TTL=900000
COLD_CACHE_TTL=3600000
PREFETCH_CONCURRENCY=50
PREFETCH_DEFAULT_LIMIT=20
ACTIVITY_CHECK_INTERVAL=60000

# ==============================================
# FFmpeg/Video Processing
# ==============================================
FFMPEG_SERVICE_TYPE=local
FFMPEG_PATH=/usr/local/bin/ffmpeg
FFPROBE_PATH=/usr/local/bin/ffprobe
VIDEO_PRESETS=360p,480p,720p,1080p
GENERATE_ANIMATED_PREVIEW=true
WORKER_CONCURRENCY=2
TRANSCODE_WORKER_ENABLED=true
TRANSCODE_WORKER_CONCURRENCY=2

# Render
RENDER_ENABLED=true
STREAM_EVENTS_WORKER_ENABLED=true

# ==============================================
# OAuth Configuration
# ==============================================
OAUTH_CLIENT_ID=https://exprsn.io/client-metadata.json
OAUTH_ISSUER=http://localhost:3002
# OAUTH_PRIVATE_KEY=

# AT Protocol Service
ATPROTO_SERVICE_ENDPOINT=http://localhost:3002

# ==============================================
# Security
# ==============================================

# JWT Secret (generate: openssl rand -base64 32)
JWT_SECRET=

# Encryption key for payment credentials (generate: openssl rand -hex 32)
ENCRYPTION_KEY=

# ==============================================
# Email (Mailhog for local dev)
# ==============================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@exprsn.io
EMAIL_DIGEST_ENABLED=true

# ==============================================
# Push Notifications (optional)
# ==============================================

# Firebase Cloud Messaging
# FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_CLIENT_EMAIL=

# Apple Push Notification Service
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_KEY_PATH=
APNS_BUNDLE_ID=io.exprsn.app

# ==============================================
# Payment Providers (optional)
# ==============================================
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=

# ==============================================
# ML/AI APIs (optional)
# ==============================================
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ==============================================
# RabbitMQ (optional)
# ==============================================
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ==============================================
# Logging
# ==============================================
LOG_LEVEL=debug

# ==============================================
# TLS / HTTPS
# ==============================================
TLS_ENABLED=false
TLS_CERT_PATH=deploy/nginx/ssl/fullchain.pem
TLS_KEY_PATH=deploy/nginx/ssl/privkey.pem

# ==============================================
# Certificate Authority Auto-Bootstrap
# ==============================================
CA_AUTO_BOOTSTRAP=true

# ==============================================
# Environment Selection
# ==============================================
# Set to development, staging, or production
# Controls which .env file is loaded:
#   development → .env (default)
#   staging     → .env.staging
#   production  → .env.production
EXPRSN_ENV=development
