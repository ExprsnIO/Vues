# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://exprsn:exprsn_dev@localhost:5432/exprsn

# Redis
REDIS_URL=redis://localhost:6379

# OpenSearch
#OPENSEARCH_URL=http://localhost:9200

# DigitalOcean Spaces (use MinIO for local dev)
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=exprsn-uploads
DO_SPACES_KEY=minioadmin
DO_SPACES_SECRET=minioadmin
DO_SPACES_ENDPOINT=http://localhost:9000
DO_SPACES_CDN=http://localhost:9000/exprsn-processed

# OAuth (generate these for your app)
OAUTH_CLIENT_ID=https://exprsn.io/client-metadata.json
OAUTH_PRIVATE_KEY=

# ML APIs (optional for local dev)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Jetstream
JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe

# PDS Configuration
PDS_ENABLED=true
PDS_DOMAIN=localhost:3000
PDS_DID_METHOD=did:plc
PDS_DATA_PATH=./data

# Federation / AT Protocol
# The service DID for this instance (did:web or did:plc).
# For production, set to did:web:<your-domain>  (e.g. did:web:exprsn.io)
SERVICE_DID=did:web:localhost%3A3000
# The publicly-reachable URL for this instance's PDS XRPC endpoint
PDS_ENDPOINT=http://localhost:3000/xrpc
# The public relay WebSocket endpoint served by this instance (if RELAY_ENABLED=true)
# RELAY_ENDPOINT=wss://localhost:3000/xrpc/com.atproto.sync.subscribeRepos
# AppView endpoint if running a separate appview service
# APPVIEW_ENDPOINT=

# Enable the internal relay/firehose (required for emitting commits to federation)
RELAY_ENABLED=false
# Relay protocol configuration (all default to true when relay is enabled)
RELAY_SOCKETIO=true
RELAY_WEBSOCKET=true
RELAY_JETSTREAM=true
RELAY_MAX_WS_SUBSCRIBERS=1000
RELAY_MAX_JETSTREAM_SUBSCRIBERS=5000
RELAY_VERIFY_SIGNATURES=false

# Enable inbound federation consumer (subscribes to remote relay firehoses)
FEDERATION_CONSUMER_ENABLED=false

# PLC directory URL for did:plc resolution (defaults to https://plc.directory)
PLC_URL=https://plc.directory

# Inter-service authentication for federation push endpoints.
# Set FEDERATION_REQUIRE_AUTH=false only for local development.
FEDERATION_REQUIRE_AUTH=true
# Certificate ID and private key for signing outbound federation requests
# (issued by the Exprsn CA — see /xrpc/io.exprsn.admin.ca.* endpoints)
# FEDERATION_CERTIFICATE_ID=
# FEDERATION_PRIVATE_KEY=

# Comma-separated list of hostnames that are Exprsn instances (use Socket.IO protocol).
# All other relay endpoints use the standard AT Protocol WebSocket + CBOR protocol.
# EXPRSN_RELAY_HOSTS=exprsn.io,staging.exprsn.io

# Blob Storage (local or s3)
BLOB_STORAGE_TYPE=local
BLOB_STORAGE_PATH=./data/blobs

# Prefetch Configuration
PREFETCH_ENABLED=true
HOT_CACHE_TTL=300000
WARM_CACHE_TTL=900000
COLD_CACHE_TTL=3600000
PREFETCH_CONCURRENCY=50
PREFETCH_DEFAULT_LIMIT=20
ACTIVITY_CHECK_INTERVAL=60000

# FFmpeg Service
FFMPEG_SERVICE_TYPE=local
FFMPEG_PATH=/usr/local/bin/ffmpeg
FFPROBE_PATH=/usr/local/bin/ffprobe
VIDEO_PRESETS=360p,480p,720p,1080p
GENERATE_ANIMATED_PREVIEW=true
WORKER_CONCURRENCY=2

# Push Notifications (FCM - Firebase Cloud Messaging)
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Push Notifications (APNs - Apple Push Notification Service)
# Optional - FCM can also handle iOS if you use FCM tokens
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=
APNS_BUNDLE_ID=io.exprsn.app

# Email Configuration
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@exprsn.io
