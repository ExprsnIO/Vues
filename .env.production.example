# ============================================================
# Exprsn Production Environment Variables
# Copy to .env.production and fill in values
# Used by docker-compose.prod.yml
# ============================================================

# --- Core ---
NODE_ENV=production

# --- Database ---
DATABASE_URL=postgresql://exprsn:CHANGE_ME@postgres:5432/exprsn

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- S3/MinIO Storage ---
S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=exprsn
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=exprsn
DO_SPACES_KEY=your-access-key
DO_SPACES_SECRET=your-secret-key
DO_SPACES_CDN=https://cdn.exprsn.io
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# --- Security ---
JWT_SECRET=generate-a-64-char-random-string
ENCRYPTION_KEY=generate-a-32-byte-hex-key
OAUTH_PRIVATE_KEY=your-rsa-private-key-pem

# --- Application URLs ---
APP_URL=https://exprsn.io
NEXT_PUBLIC_API_URL=https://api.exprsn.io
NEXT_PUBLIC_WS_URL=wss://api.exprsn.io
CORS_ORIGIN=https://exprsn.io,https://www.exprsn.io

# --- PDS / Federation ---
PDS_HOSTNAME=exprsn.io
PDS_ENABLED=true
SERVICE_DID=did:web:exprsn.io
PDS_ENDPOINT=https://api.exprsn.io/xrpc
RELAY_ENABLED=false
RELAY_HOSTNAME=relay.exprsn.io

# --- Video Processing ---
RENDER_WORKER_REPLICAS=2
GPU_ENABLED=false
TRANSCODE_WORKER_ENABLED=true
TRANSCODE_WORKER_CONCURRENCY=2

# --- Prefetch ---
PREFETCH_AUTH_TOKEN=generate-with-scripts/generate-prefetch-token.ts
PREFETCH_PRODUCER_ENABLED=true

# --- Rate Limits ---
# Defaults: anonymous=30/min, user=60/min, admin=120/min
# Override via admin settings or these env vars

# --- Logging ---
LOG_LEVEL=info

# --- Monitoring ---
METRICS_ENABLED=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
GRAFANA_ROOT_URL=https://grafana.exprsn.io

# --- Optional: OpenSearch ---
# OPENSEARCH_URL=http://opensearch:9200

# --- Optional: AI ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# --- Optional: Creator Fund ---
# CREATOR_FUND_ENABLED=true
# CREATOR_FUND_MONTHLY_POOL=10000
